   DEBUG: 2026-03-22 12:43:00,628:      pdf_renderer.py:  470: printSegment: '
   DEBUG: 2026-03-22 12:43:00,629:      pdf_renderer.py:  470: printSegment:  theorem |
   DEBUG: 2026-03-22 12:43:00,630:      pdf_renderer.py:  470: printSegment:  
